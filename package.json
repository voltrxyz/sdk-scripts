{
  "name": "voltr-integration-scripts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "typecheck": "tsc -p tsconfig.check.json",
    "test": "TSX_TSCONFIG_PATH=tsconfig.check.json node --import tsx --test \"packages/*/src/**/*.test.ts\" \"apps/*/src/**/*.test.ts\" \"scripts/**/*.test.mjs\"",
    "check:terminology": "node scripts/check-terminology.mjs",
    "check": "pnpm run typecheck && pnpm run build && pnpm run test",
    "cli": "TSX_TSCONFIG_PATH=tsconfig.check.json tsx apps/cli/src/index.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "overrides": {
      "@kamino-finance/farms-sdk": "3.2.24"
    }
  }
}
