{
  // Root config whose only job is to give `tsx` the source `paths` it
  // auto-discovers from the repo root. That makes bare
  // `pnpm exec tsx examples/src/<group>/<file>.ts` resolve `@voltr/scripts-*` to
  // SOURCE with no build — only `pnpm install` is needed. It also gives editors
  // go-to-source.
  //
  // The build/typecheck pipelines never rely on this file: `pnpm typecheck` uses
  // `-p tsconfig.check.json`, per-package builds use their own `tsconfig.json`,
  // and the examples typecheck uses `-p examples/tsconfig.json` — all explicit.
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "paths": {
      "@voltr/scripts-core": ["./packages/core/src/index.ts"],
      "@voltr/scripts-core/testing": ["./packages/core/src/testing.ts"],
      "@voltr/scripts-kamino": ["./packages/kamino/src/index.ts"],
      "@voltr/scripts-spot": ["./packages/spot/src/index.ts"],
      "@voltr/scripts-trustful": ["./packages/trustful/src/index.ts"]
    }
  },
  "include": [
    "packages/*/src/**/*",
    "apps/*/src/**/*",
    "examples/src/**/*",
    "examples/scripts/**/*"
  ]
}
