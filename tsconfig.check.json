{
  // Whole-workspace typecheck config. Unlike the per-package build tsconfigs
  // (which resolve `@voltr/scripts-core` to its built `dist/`), this config maps
  // the package to its SOURCE so the entire repo — including *.test.ts files —
  // type-checks in a single pass with no prior build and no network access.
  //
  // The same `paths` are reused at runtime by tsx (via TSX_TSCONFIG_PATH in the
  // root `test`/`cli` scripts), so tests and the CLI also run straight from
  // source. See docs/testing.md.
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "paths": {
      "@voltr/scripts-core": ["./packages/core/src/index.ts"],
      "@voltr/scripts-core/testing": ["./packages/core/src/testing.ts"]
    }
  },
  "include": ["packages/*/src/**/*", "apps/*/src/**/*"]
}
